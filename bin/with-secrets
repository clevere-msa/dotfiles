#!/usr/bin/env bash
set -euo pipefail
set +x

usage() {
  cat >&2 <<'EOF'
with-secrets: run a command with secrets loaded from pass

Usage:
  with-secrets --app APP --auth AUTH --user USER -- COMMAND...
  with-secrets --pass-path PATH -- COMMAND...

Auth sources:
  oidc-shared      -> oidc/employees/<user>
  oidc-dedicated   -> oidc/<app>/<user>
  ldap             -> ldap/pos_ext/<user>

Options:
  --app APP            Application id (required for oidc-dedicated)
  --auth AUTH          oidc-shared | oidc-dedicated | ldap
  --user USER          Username
  --pass-path PATH     Explicit pass path override
  --env NAME           Export secret as NAME (default AUTH_PASSWORD)
  -n, --dry-run        Print resolved path + command only
  -h, --help           Show this help

Env exported to the command:
  AUTH_APP, AUTH_SOURCE, AUTH_USER, AUTH_PASSWORD (or custom NAME)
EOF
}

APP_ID=""
AUTH_SOURCE=""
AUTH_USER=""
PASS_PATH=""
ENV_NAME="AUTH_PASSWORD"
DRY_RUN=0
CMD=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --app)
      APP_ID="${2:-}"
      shift 2
      ;;
    --auth)
      AUTH_SOURCE="${2:-}"
      shift 2
      ;;
    --user)
      AUTH_USER="${2:-}"
      shift 2
      ;;
    --pass-path)
      PASS_PATH="${2:-}"
      shift 2
      ;;
    --env)
      ENV_NAME="${2:-}"
      shift 2
      ;;
    -n|--dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      CMD=("$@")
      break
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
  esac
done

if [[ ${#CMD[@]} -eq 0 ]]; then
  echo "ERROR: missing command (use -- COMMAND...)" >&2
  usage
  exit 2
fi

if [[ -n "$ENV_NAME" ]]; then
  if [[ ! "$ENV_NAME" =~ ^[A-Z_][A-Z0-9_]*$ ]]; then
    echo "ERROR: --env must be a valid uppercase env var name" >&2
    exit 2
  fi
fi

if [[ -z "$PASS_PATH" ]]; then
  if [[ -z "$AUTH_SOURCE" || -z "$AUTH_USER" ]]; then
    echo "ERROR: --auth and --user required unless --pass-path is provided" >&2
    usage
    exit 2
  fi

  case "$AUTH_SOURCE" in
    oidc-shared|oidc_shared|employees)
      PASS_PATH="oidc/employees/${AUTH_USER}"
      ;;
    oidc-dedicated|oidc_dedicated|oidc)
      if [[ -z "$APP_ID" ]]; then
        echo "ERROR: --app is required for oidc-dedicated" >&2
        usage
        exit 2
      fi
      PASS_PATH="oidc/${APP_ID}/${AUTH_USER}"
      ;;
    ldap|ldap-shared|pos_ext)
      PASS_PATH="ldap/pos_ext/${AUTH_USER}"
      ;;
    *)
      echo "ERROR: unknown --auth value: $AUTH_SOURCE" >&2
      usage
      exit 2
      ;;
  esac
fi

if ! command -v pass >/dev/null 2>&1; then
  echo "ERROR: pass is not installed or not on PATH" >&2
  exit 1
fi

if (( DRY_RUN )); then
  printf 'Resolved pass path: %s\n' "$PASS_PATH"
  printf 'Command: %q ' "${CMD[@]}"
  printf '\n'
  exit 0
fi

AUTH_PASSWORD="$(pass show "$PASS_PATH" 2>/dev/null | head -n 1 || true)"
if [[ -z "$AUTH_PASSWORD" ]]; then
  echo "ERROR: no secret found at pass path: $PASS_PATH" >&2
  exit 1
fi

export AUTH_APP="$APP_ID"
export AUTH_SOURCE="$AUTH_SOURCE"
export AUTH_USER="$AUTH_USER"
if [[ "$ENV_NAME" == "AUTH_PASSWORD" ]]; then
  export AUTH_PASSWORD="$AUTH_PASSWORD"
else
  export "$ENV_NAME=$AUTH_PASSWORD"
fi

exec "${CMD[@]}"
